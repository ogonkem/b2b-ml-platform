   "source": [
    "def get_age(name, YOB, current_year=2026):\n",
    "    age = current_year - YOB\n",
    "    print(f\"Name: {name}\\n age: {age}\")\n",
    "\n",
    "get_age(\"peter\", 2019)"
   ]
